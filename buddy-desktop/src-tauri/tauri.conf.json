{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Buddy Desktop",
  "version": "0.1.0",
  "identifier": "studio.buddy.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "status-popup",
        "title": "Buddy",
        "width": 320,
        "height": 420,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/buddy-server"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
